{
  "extends": "@workspace/typescript-config/base.json",

  "compilerOptions": {
    "target": "ES2022",

    "module": "ESNext",
    "moduleResolution": "Bundler",

    "outDir": "dist",

    "baseUrl": ".",

    "paths": {
      "@/*": ["./src/*"]
    },

    "strict": true,
    "skipLibCheck": true
  },

  "include": ["src", "drizzle.config.ts", "tsup.config.ts"]
}
