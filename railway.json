{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm --filter @workspace/validator build && pnpm --filter @workspace/api build"
  },
  "deploy": {
    "preDeployCommand": "pnpm --filter @workspace/api db:migrate",
    "startCommand": "node apps/api/dist/server.js",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
