{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "DATABASE_URL",
    "PAYLOAD_SECRET",
    "R2_ACCESS_KEY_ID",
    "R2_SECRET_ACCESS_KEY",
    "R2_ENDPOINT",
    "R2_BUCKET",
    "R2_PUBLIC_URL"
  ],
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },

    "lint": {
      "dependsOn": ["^lint"]
    },

    "format": {
      "dependsOn": ["^format"]
    },

    "typecheck": {
      "dependsOn": ["^typecheck"]
    },

    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
